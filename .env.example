# Шаблон переменных: скопируйте в .env.local (см. docker-compose env_file).
# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=your_telegram_id_here

# Hiddify
HIDDIFY_URL=https://YOUR_VPS_IP/YOUR_SECRET/
HIDDIFY_API_KEY=your_hiddify_api_key
MARIADB_ROOT_PASSWORD=your_strong_password_here
MYSQL_PASSWORD=your_strong_mysql_password_here
REDIS_PASSWORD=your_strong_redis_password_here

# MTProxy
MTPROXY_LOG=/mtproxy/logs/proxy.log
MTPROXY_CONFIG=/mtproxy/data/config
# Публичный адрес/порт для ссылок tg://proxy (как снаружи виден VPS)
MTPROXY_PUBLIC_HOST=YOUR_VPS_IP
MTPROXY_PUBLIC_PORT=8443

# Settings
MONITOR_INTERVAL=10m
WARNING_TTL=24h
DEVICE_LIMIT=5
DB_PATH=/app/data/database.db
