# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=your_telegram_id_here

# Hiddify
HIDDIFY_DOMAIN=https://arengate.tech
HIDDIFY_ADMIN_PATH=YOUR_ADMIN_PATH
HIDDIFY_CLIENT_PATH=YOUR_CLIENT_PATH
HIDDIFY_API_KEY=YOUR_ADMIN_UUID

# User defaults in Hiddify
USER_PACKAGE_DAYS=90
USER_USAGE_LIMIT_GB=1000

# Webhook (production). Leave empty to use long polling (local dev).
WEBHOOK_URL=https://bot.arengate.tech
WEBHOOK_LISTEN=:8080

# Domain shown in VPN links sent to users (replaces raw IP from Hiddify).
USERS_PROXY_HOST=users.arengate.tech

# Database
DB_PATH=./data/database.db
